{
  "name": "study-widget",
  "version": "1.0.0",
  "description": "Desktop study to-do widget",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently --hide 0 -n vite,electron -c cyan,yellow \"vite\" \"wait-on tcp:5173 && electron .\"",
    "build": "vite build",
    "dist": "vite build && electron-packager . \"Study Widget\" --platform=win32 --arch=x64 --out=release --overwrite --asar --ignore=\"/node_modules\" --ignore=\"/src\" --ignore=\"/release\" --ignore=\"index\\.html\" --ignore=\"vite\\.config\\.js\" --ignore=\"package-lock\\.json\"",
    "dist-builder": "vite build && electron-builder",
    "preview": "vite preview",
    "patch-clawd": "node scripts/install-clawd-patch.js"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@electron/asar": "^3.2.0",
    "@electron/packager": "^19.1.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.study.widget",
    "productName": "Study Widget",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
